{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://resolveagent.io/schemas/skill-manifest.json",
  "title": "ResolveAgent Skill Manifest",
  "type": "object",
  "required": ["name", "version", "entry_point"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique skill name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "entry_point": {
      "type": "string",
      "description": "Python module:function format"
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permissions": {
      "$ref": "#/$defs/permissions"
    },
    "skill_type": {
      "type": "string",
      "enum": ["general", "scenario"],
      "default": "general",
      "description": "Skill classification: general (utility) or scenario (troubleshooting)"
    },
    "scenario": {
      "$ref": "#/$defs/scenario_config"
    }
  },
  "$defs": {
    "parameter": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["string", "number", "boolean", "object", "array"] },
        "description": { "type": "string" },
        "required": { "type": "boolean", "default": false },
        "default": {},
        "enum": { "type": "array", "items": { "type": "string" } }
      }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "network_access": { "type": "boolean", "default": false },
        "file_system_read": { "type": "boolean", "default": false },
        "file_system_write": { "type": "boolean", "default": false },
        "allowed_hosts": { "type": "array", "items": { "type": "string" } },
        "max_memory_mb": { "type": "integer", "default": 256 },
        "max_cpu_seconds": { "type": "integer", "default": 30 },
        "timeout_seconds": { "type": "integer", "default": 60 }
      }
    },
    "troubleshooting_step": {
      "type": "object",
      "required": ["id", "name", "step_type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "step_type": { "type": "string", "enum": ["collect", "diagnose", "verify", "action"] },
        "command": { "type": "string" },
        "skill_ref": { "type": "string" },
        "expected_output": { "type": "string" },
        "condition": { "type": "string" },
        "timeout_seconds": { "type": "integer", "default": 30 },
        "order": { "type": "integer", "default": 0 }
      }
    },
    "solution_output_template": {
      "type": "object",
      "properties": {
        "include_symptoms": { "type": "boolean", "default": true },
        "include_evidence": { "type": "boolean", "default": true },
        "include_steps": { "type": "boolean", "default": true },
        "include_resolution": { "type": "boolean", "default": true },
        "custom_sections": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scenario_config": {
      "type": "object",
      "required": ["domain"],
      "properties": {
        "domain": { "type": "string", "description": "Problem domain (e.g., kubernetes, database, network)" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "troubleshooting_flow": {
          "type": "array",
          "items": { "$ref": "#/$defs/troubleshooting_step" }
        },
        "output_template": { "$ref": "#/$defs/solution_output_template" },
        "severity_levels": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["critical", "high", "medium", "low"]
        }
      }
    }
  }
}
