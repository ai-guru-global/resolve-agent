# =============================================================================
# ResolveAgent Docker Deployment - Environment Configuration
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
RESOLVEAGENT_VERSION=latest
DOCKER_REGISTRY=ghcr.io/ai-guru-global

# -----------------------------------------------------------------------------
# Port Mapping (host:container)
# -----------------------------------------------------------------------------
PLATFORM_HTTP_PORT=8080
PLATFORM_GRPC_PORT=9090
RUNTIME_GRPC_PORT=9091
WEBUI_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
RESOLVEAGENT_DATABASE_HOST=postgres
RESOLVEAGENT_DATABASE_PORT=5432
RESOLVEAGENT_DATABASE_USER=resolveagent
RESOLVEAGENT_DATABASE_PASSWORD=resolveagent
RESOLVEAGENT_DATABASE_DBNAME=resolveagent
RESOLVEAGENT_DATABASE_SSLMODE=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
RESOLVEAGENT_REDIS_ADDR=redis:6379
RESOLVEAGENT_REDIS_PASSWORD=
RESOLVEAGENT_REDIS_DB=0
REDIS_MAXMEMORY=256mb

# -----------------------------------------------------------------------------
# NATS JetStream
# -----------------------------------------------------------------------------
RESOLVEAGENT_NATS_URL=nats://nats:4222

# -----------------------------------------------------------------------------
# Agent Runtime
# -----------------------------------------------------------------------------
RESOLVEAGENT_RUNTIME_GRPC_ADDR=runtime:9091
RESOLVEAGENT_AGENT_POOL_MAX_SIZE=100
RESOLVEAGENT_SELECTOR_DEFAULT_STRATEGY=hybrid
RESOLVEAGENT_SELECTOR_CONFIDENCE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Higress AI Gateway Integration
# -----------------------------------------------------------------------------
RESOLVEAGENT_GATEWAY_ENABLED=false
RESOLVEAGENT_GATEWAY_ADMIN_URL=http://higress:8888
RESOLVEAGENT_GATEWAY_SYNC_INTERVAL=30s

# LLM Model Routing (through Higress)
RESOLVEAGENT_GATEWAY_MODEL_ROUTING_ENABLED=true
RESOLVEAGENT_GATEWAY_MODEL_ROUTING_DEFAULT_MODEL=qwen-plus

# Gateway Authentication
RESOLVEAGENT_GATEWAY_AUTH_ENABLED=false
RESOLVEAGENT_GATEWAY_AUTH_JWT_SECRET=
RESOLVEAGENT_GATEWAY_LOAD_BALANCER_STRATEGY=round_robin

# -----------------------------------------------------------------------------
# LLM API Keys (configure at least one)
# -----------------------------------------------------------------------------
RESOLVEAGENT_LLM_QWEN_API_KEY=
RESOLVEAGENT_LLM_WENXIN_API_KEY=
RESOLVEAGENT_LLM_ZHIPU_API_KEY=

# -----------------------------------------------------------------------------
# Telemetry (OpenTelemetry)
# -----------------------------------------------------------------------------
RESOLVEAGENT_TELEMETRY_ENABLED=false
RESOLVEAGENT_TELEMETRY_OTLP_ENDPOINT=
