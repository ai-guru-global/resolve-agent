# ResolveNet Docker Compose Environment
RESOLVENET_DATABASE_HOST=postgres
RESOLVENET_DATABASE_PORT=5432
RESOLVENET_DATABASE_USER=resolvenet
RESOLVENET_DATABASE_PASSWORD=resolvenet
RESOLVENET_DATABASE_DBNAME=resolvenet
RESOLVENET_REDIS_ADDR=redis:6379
RESOLVENET_NATS_URL=nats://nats:4222
RESOLVENET_RUNTIME_GRPC_ADDR=runtime:9091

# LLM API Keys (configure at least one)
# RESOLVENET_LLM_QWEN_API_KEY=
# RESOLVENET_LLM_WENXIN_API_KEY=
# RESOLVENET_LLM_ZHIPU_API_KEY=
